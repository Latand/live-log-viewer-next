# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.server.log

# env files (can opt-in for committing if needed)
.env*
.privacy-known-values
/.privacy-tools/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
prod.log

# local agent-session artifacts (but ship project skills with the repo)
/.claude/*
!/.claude/skills/
/.tmux-multi-agent/
/fixtures/demo-home/.capture/

# ad-hoc readable-tool review stills (issue #475): regenerate with
# `bun scripts/readable-tool-shots.tsx`. Committed screenshots must instead go
# through the provenance-signed demo-capture pipeline, so keep these local.
/docs/media/readable-tools/

# issue-499 evidence: raw chrome captures stay local (digests live in capture-manifest.json)
docs/screenshots/issue-499/*.png
docs/screenshots/issue-499/captures.list
docs/screenshots/issue-499/geometry.list
