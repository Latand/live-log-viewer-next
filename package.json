{
  "name": "agent-log-viewer",
  "version": "0.11.7",
  "bin": {
    "agent-log-viewer": "bin/cli.mjs",
    "agent-log-viewer-mcp": "bin/mcp-server.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "scripts": {
    "dev": "NODE_ENV=development next dev --webpack --hostname 127.0.0.1",
    "build": "next build --webpack && bun run build:mcp",
    "build:mcp": "bun scripts/build-mcp.ts",
    "demo:capture": "bun scripts/demo-capture.ts",
    "demo:motion": "bun scripts/demo-motion.ts",
    "start": "next start",
    "lint": "eslint",
    "prepack": "node scripts/prepack.mjs",
    "privacy:check": "LLV_PRIVACY_KNOWN_VALUE_FINGERPRINTS_FILE=scripts/privacy-known-value-fingerprints.json LLV_PRIVACY_OCR_LANGUAGES=eng+ukr bun scripts/privacy-publication-gate.ts --require-known-values --base origin/main",
    "privacy:fingerprints": "bun scripts/generate-privacy-known-value-fingerprints.ts",
    "privacy:github-audit": "LLV_PRIVACY_KNOWN_VALUE_FINGERPRINTS_FILE=scripts/privacy-known-value-fingerprints.json bun scripts/privacy-github-audit.ts",
    "privacy:placeholders": "bun scripts/generate-privacy-placeholders.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "entities": "^7.0.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.10.6",
    "playwright-core": "1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "description": "Local web UI that renders Codex / Claude Code agent logs as a live chat-style feed with a session parentage tree",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latand/live-log-viewer-next.git"
  },
  "license": "MIT"
}
